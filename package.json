{
  "name": "zhongwen-dash",
  "version": "1.0.0",
  "description": "Modern Express and Node app shell for the Zhongwen study dashboard.",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"tsc --project tsconfig.frontend.json --watch\" \"tsx watch server/index.ts\"",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc --project tsconfig.json",
    "build:frontend": "tsc --project tsconfig.frontend.json",
    "start": "node dist/server/index.js",
    "icons:trending": "tsx scripts/download-trending-icons.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node -e \"console.log('No automated tests configured yet.')\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joapoc/zhongwen-dash.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/joapoc/zhongwen-dash/issues"
  },
  "homepage": "https://github.com/joapoc/zhongwen-dash#readme",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "chinese-lexicon": "^1.0.43",
    "cors": "^2.8.6",
    "deepl": "^1.0.13",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "hanzi-writer": "^3.7.3",
    "hanzi-writer-data": "^2.0.1",
    "jieba-wasm": "^2.4.0",
    "jsdom": "^29.0.2",
    "mongoose": "^9.4.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
